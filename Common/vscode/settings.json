{
  // Telemetry
  "telemetry.telemetryLevel": "off",

  // Editor
  "editor.tabSize": 2,
  "editor.autoIndent": "full",
  "editor.insertSpaces": true,
  "editor.lineNumbers": "on",
  "editor.fontFamily": "Hack",
  "editor.fontSize": 12,
  "editor.minimap.showSlider": "always",
  "editor.suggestSelection": "first",
  "editor.formatOnSave": false,
  "editor.renderWhitespace": "selection",

  // Files
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.eol": "auto",

  // Window
  "window.commandCenter": false,

  // Language overrides
  "[go]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "golang.go",
    "editor.insertSpaces": false,
    "editor.tabSize": 4
  },

  "[c][cpp]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "ms-vscode.cpptools",
    "editor.tabSize": 4
  },

  "[python]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.tabSize": 4
  },

  "[javascript][javascriptreact][typescript][typescriptreact]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },

  "[astro]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "astro-build.astro-vscode"
  },

  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  "[makefile]": {
    "editor.insertSpaces": false,
    "editor.tabSize": 4
  },

  // File Explorer
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,

  // Workbench
  "workbench.editor.empty.hint": "hidden",
  "workbench.colorTheme": "Tokyo Night Storm",
  "workbench.iconTheme": "vscode-icons",
  "workbench.activityBar.location": "top",
  "workbench.colorCustomizations": {
    "editorWhitespace.foreground": "#a9b1d6"
  },
  "workbench.secondarySideBar.defaultVisibility": "hidden",

  // Chat
  "chat.titleBar.openInAgentsWindow.enabled": false,

  // Extensions
  "extensions.ignoreRecommendations": true,

  "C_Cpp.clang_format_style": "file",
  "C_Cpp.clang_format_fallbackStyle": "{ BasedOnStyle: LLVM, IndentWidth: 4, UseTab: Never, ColumnLimit: 80, BreakBeforeBraces: Linux, AllowShortIfStatementsOnASingleLine: AllIfsAndElse, AllowShortFunctionsOnASingleLine: InlineOnly }",
  "C_Cpp.autoAddFileAssociations": false,

  "go.formatTool": "goimports",
  "go.useLanguageServer": true,

  "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.latex.recipe.default": "latexmk (xelatex)", // XeLaTeX is used for smaller PDF file sizes

  "Lua.diagnostics.globals": ["vim", "hl"],

  "python.languageServer": "None",
  "ty.inlayHints.callArgumentNames": false,
  "ty.inlayHints.variableTypes": false,

  "vim.useSystemClipboard": true,
  "vim.useCtrlKeys": true,
  "vim.hlsearch": true,
  "vim.handleKeys": {
    "<C-a>": false,
    "<C-f>": false
  },
  "vim.smartRelativeLine": true,

  "prettier.singleQuote": true,
  "prettier.trailingComma": "es5",

  "git.blame.editorDecoration.enabled": true,
  "git.blame.statusBarItem.enabled": false,
  "git.autoRepositoryDetection": "openEditors",

  "cSpell.useCustomDecorations": false
}
